PROJECT_NAME           = "CrossGL Translator"
PROJECT_BRIEF          = "CrossGL shader and compute translation toolkit"
OUTPUT_DIRECTORY       = docs/doxygen/build
INPUT                  = crosstl
RECURSIVE              = YES
FILE_PATTERNS          = *.py
EXCLUDE_PATTERNS       = */__pycache__/* */.pytest_cache/*
OPTIMIZE_OUTPUT_JAVA   = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
GENERATE_HTML          = NO
GENERATE_LATEX         = NO
GENERATE_XML           = YES
XML_OUTPUT             = xml
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
