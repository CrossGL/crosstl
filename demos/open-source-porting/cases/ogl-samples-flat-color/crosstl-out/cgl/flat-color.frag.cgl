#version 330 core
precision highp float;
precision highp int;

shader main {
    cbuffer Uniforms {
    vec4 Diffuse;
    };

    fragment {
    layout(std140, column_major) uniform;

    vec4 main() @location(0) @index(0) @ Color {
        vec4 Color;
        Color = Diffuse;
        return Color;
    }
    }
}
